# Used by the root docker-compose.yml (full stack: db + backend + frontend).
# Locally: copy to ".env" next to docker-compose.yml.
# In Portainer: set these as the stack's "Environment variables" instead.

POSTGRES_USER=aether
POSTGRES_PASSWORD=aether
POSTGRES_DB=aether

# Discord OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback
DISCORD_GUILD_ID=
DISCORD_ADMIN_ROLE_IDS=
DISCORD_EDITOR_ROLE_IDS=

# Session
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
SESSION_MAX_AGE=604800
FRONTEND_URL=http://localhost:3000
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
