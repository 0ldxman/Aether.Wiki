# Used by the root docker-compose.yml (full stack: db + backend + frontend).
# Locally: copy to ".env" next to docker-compose.yml.
# In Portainer: set these as the stack's "Environment variables" instead.

POSTGRES_USER=aether
POSTGRES_PASSWORD=aether
POSTGRES_DB=aether

# Discord OAuth
# NOTE: redirect_uri points at the BACKEND directly (port 8000), not the frontend -
# Next.js rewrites() drop the Set-Cookie header on proxied responses, which breaks
# the OAuth state/session cookies. Must match a Redirect registered in the Discord
# Developer Portal exactly (scheme, host, port, path).
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8000/api/auth/discord/callback
DISCORD_GUILD_ID=
DISCORD_ADMIN_ROLE_IDS=
DISCORD_EDITOR_ROLE_IDS=

# Session
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
SESSION_MAX_AGE=604800
FRONTEND_URL=http://localhost:3000
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Public URL of the backend (port 8000), reachable from the user's browser.
# Baked into the frontend bundle at build time (NEXT_PUBLIC_*).
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
